<UserControl x:Class="ProjetoCRAS.Views.MenuLateral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjetoCRAS.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="White">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" FontSize="30"
                        Content="X" Foreground="Gray"
                        Background="Transparent" BorderBrush="Transparent"
                        Height="50" Width="50"
                        x:Name="BtnX" Click="BtnX_Click"
                        Margin="10"
                        />

                <StackPanel Grid.Column="1" Orientation="Horizontal" >
                    <Image Source="/Source/Cras_Logo.png" Width="70"/>
                    <TextBlock Text="AbasteceCRAS" VerticalAlignment="Center"/>
                </StackPanel>

                

            </Grid>

            <Separator Margin="10"/>

            <Button Width="150" Height="50" Content="PlaceHolder 1" Margin="5"/>
            <Button Width="150" Height="50" Content="PlaceHolder 2" Margin="5"/>
            <Button Width="150" Height="50" Content="PlaceHolder 3" Margin="5"/>
            <Button Width="150" Height="50" Content="PlaceHolder 4" Margin="5"/>
            <Button Width="150" Height="50" Content="PlaceHolder 5" Margin="5"/>


        </StackPanel>

        <Grid Grid.Column="1" Background="#25347D" Opacity="0.5"/>

    </Grid>
</UserControl>
