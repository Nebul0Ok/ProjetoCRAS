<UserControl x:Class="AbasteceCRAS.MVVM.Views.HistoricoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
             xmlns:services="clr-namespace:AbasteceCRAS.Services"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="9*"/>
            <ColumnDefinition Width="0.1*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="1" Grid.Row="0" 
                 Text="Histórico de Movimentações"
                 FontFamily="Roboto" FontSize="20" FontWeight="Bold"
                 HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <Button Grid.Column="0" Grid.Row="0" Content="◀" Width="50" Height="30" FontSize="20"
        Command="{Binding RetornarParaHome}"/>

        <Border Grid.Row="1" Grid.Column="1"  BorderBrush="Gray" BorderThickness="1" CornerRadius="10">
            <DataGrid x:Name="dgHistorico" Margin="20" ItemsSource="{Binding Source={x:Static services:DadosService.Instance}, Path=ListaHistorico}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal" 
              HorizontalGridLinesBrush="#F0F0F0"
              RowHeight="50"
              HeadersVisibility="Column"
              Background="Transparent"
              BorderThickness="0"
              CanUserSortColumns="False" SelectionChanged="DataGrid_SelectionChanged"
              IsReadOnly="True"
              SelectionUnit="FullRow"
              MouseDown="Grid_MouseDown">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,0,0,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data/Hora" FontSize="14" Binding="{Binding DataDaOcorrencia}" Width="1.5*"/>
                    <DataGridTemplateColumn Header="Tipo" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left"
                                     Background="{Binding CorTipo}">
                                    <TextBlock Text="{Binding Ocorrencia}" FontSize="14"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Responsável" FontSize="14" Binding="{Binding Responsavel}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
