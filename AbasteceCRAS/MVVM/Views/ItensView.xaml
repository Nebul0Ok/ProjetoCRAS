<UserControl x:Class="AbasteceCRAS.MVVM.Views.ItensView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:services="clr-namespace:AbasteceCRAS.Services"
             xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="9*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀"
                    Width="50" Height="30" FontSize="20"
                    Command="{Binding RetornarParaHome}"/>

            <TextBlock Text="Gerenciamento de Itens" Grid.Column="1"
                       VerticalAlignment="Center" Margin="10,0"
                       FontSize="20" FontWeight="Bold"/>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Margin="10" VerticalAlignment="Top" Grid.Row="0" Background="Transparent" BorderBrush="Gray" BorderThickness="0.5" CornerRadius="20">

                    <StackPanel Margin="10">
                        <TextBlock Text="Adicionar Novo Item" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="Nome do item" FontSize="10" FontWeight="Bold"/>

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0" Text="{Binding NomeItem, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="+Adicionar"
                                    Command="{Binding AdicionarItem}"/>
                        </Grid>
                        
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" Margin="10" 
                         ItemsSource="{Binding Source={x:Static services:DadosService.Instance}, Path=ListaProduto}"
                         SelectedItem="{Binding ItemSelecionado, Mode=TwoWay}"
                         HorizontalContentAlignment="Stretch" BorderBrush="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="20" 
                                        BorderBrush="Gray" BorderThickness="1"
                                        HorizontalAlignment="Stretch">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{Binding NomeItem}" Grid.Row="0" FontSize="20" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" Grid.Row="1">
                                            <TextBlock Text="{Binding QuantidadeDeTipos}" FontSize="15" Foreground="#777373"/>
                                            <TextBlock Text=" tipo(s)" FontSize="15" Foreground="#777373"/>
                                        </StackPanel>

                                    </Grid>

                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>


                <ItemsControl>
                </ItemsControl>
                
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="8.8*"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>

                <Border Margin="10" VerticalAlignment="Top" Grid.Row="0" Background="Transparent" BorderBrush="Gray" BorderThickness="0.5" CornerRadius="20">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tipo de Item" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ItemSelecionado.NomeItem}" FontSize="15" FontWeight="Bold" Padding="20,0,0,0" Foreground="Red"/>
                        </StackPanel>
                        
                        <TextBlock Text="Adicionar tipo" FontSize="10" FontWeight="Bold"/>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0" Text="{Binding NomeDoTipo}"/>
                            <Button Grid.Column="1" Content="+Adicionar" Command="{Binding AdicionarTipo}"/>
                        </Grid>

                        <CheckBox Content="É Perecível?" FontSize="15" FontWeight="Bold" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Insira a validade" FontSize="10" FontWeight="Bold"/>

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0"/>
                            <Expander Grid.Column="1"/>
                            <Button Grid.Column="2" Content="+Adicionar"/>
                        </Grid>

                        <ItemsControl/>

                    </StackPanel>
                </Border>

                <Button Height="40" Width="70" Grid.Row="1" Style="{StaticResource BotaoIcone2}" HorizontalAlignment="Left" Margin="20"
                        Command="{Binding ExcluirItem}"
                        Background="#ff0000" VerticalAlignment="Center">
                    <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" Name="svg4" Width="24" Height="24">
                        <Canvas.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Canvas.RenderTransform>
                        <Canvas.Resources/>
                        <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="path2" StrokeThickness="2" Stroke="White" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.Data>
                                <PathGeometry Figures="M4 6H20M16 6L15.7294 5.18807C15.4671 4.40125 15.3359 4.00784 15.0927 3.71698C14.8779 3.46013 14.6021 3.26132 14.2905 3.13878C13.9376 3 13.523 3 12.6936 3H11.3064C10.477 3 10.0624 3 9.70951 3.13878C9.39792 3.26132 9.12208 3.46013 8.90729 3.71698C8.66405 4.00784 8.53292 4.40125 8.27064 5.18807L8 6M18 6V16.2C18 17.8802 18 18.7202 17.673 19.362C17.3854 19.9265 16.9265 20.3854 16.362 20.673C15.7202 21 14.8802 21 13.2 21H10.8C9.11984 21 8.27976 21 7.63803 20.673C7.07354 20.3854 6.6146 19.9265 6.32698 19.362C6 18.7202 6 17.8802 6 16.2V6M14 10V17M10 10V17" FillRule="NonZero"/>
                            </Path.Data>
                        </Path>
                    </Canvas>
                    
                    
                    
                </Button>


            </Grid>

        </Grid>
        
    </Grid>
</UserControl>
