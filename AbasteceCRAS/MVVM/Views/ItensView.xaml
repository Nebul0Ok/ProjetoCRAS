<UserControl x:Class="AbasteceCRAS.MVVM.Views.ItensView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:services="clr-namespace:AbasteceCRAS.Services"
             xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="9*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="◀"
                    Width="50" Height="30" FontSize="20"
                    Command="{Binding RetornarParaHome}"/>

            <TextBlock Text="Gerenciamento de Itens" Grid.Column="1"
                       VerticalAlignment="Center" Margin="10,0"
                       FontSize="20" FontWeight="Bold"/>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Margin="10" VerticalAlignment="Top" Grid.Row="0" Background="Transparent" BorderBrush="Gray" BorderThickness="0.5" CornerRadius="20">

                    <StackPanel Margin="10">
                        <TextBlock Text="Adicionar Novo Item" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="Nome do item" FontSize="10" FontWeight="Bold"/>

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0" Text="{Binding NomeItem, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="+Adicionar" Style="{StaticResource Botoes}"
                                    Command="{Binding AdicionarItem}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkPerecivel"/>
                            <TextBlock Text="É perecível?"/>

                        </StackPanel>

                    </StackPanel>
                </Border>
                

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Nome do item:" Margin="20,0,10,0"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,20,0"
                             Text="{Binding NomeItemPesquisado, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                
                
                <ListBox Grid.Row="2" Margin="10" 
                         ItemsSource="{Binding ListaProduto}"
                         SelectedItem="{Binding ItemSelecionado, Mode=TwoWay}"
                         HorizontalContentAlignment="Stretch" BorderBrush="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="20" 
                                        BorderBrush="Gray" BorderThickness="1"
                                        HorizontalAlignment="Stretch">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="8*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{Binding NomeItem}" Grid.Row="0" FontSize="20" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" Grid.Row="1">
                                            <TextBlock Text="{Binding QuantidadeDeTipos, UpdateSourceTrigger=PropertyChanged}" FontSize="15" Foreground="#777373"/>
                                            <TextBlock Text=" tipo(s)" FontSize="15" Foreground="#777373"/>
                                        </StackPanel>

                                    </Grid>

                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    
                </Grid.ColumnDefinitions>

                <Border Margin="10" VerticalAlignment="Top" Grid.Row="0" Background="Transparent" BorderBrush="Gray" BorderThickness="0.5" CornerRadius="20">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tipo de Item" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ItemSelecionado.NomeItem}" FontSize="15" FontWeight="Bold" Padding="20,0,0,0" Foreground="Red"/>
                        </StackPanel>

                        <TextBlock Text="Adicionar tipo" FontSize="10" FontWeight="Bold"/>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0" Text="{Binding NomeDoTipo}"/>
                        </Grid>

                        
                        <TextBlock Text="Adicionar quantidade" FontSize="10" FontWeight="Bold"/>

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Margin="0,0,10,0" Text="{Binding QuantidadeTipoItem}"/>
                            <Button Grid.Column="1"
                                    Content="+Adicionar" Style="{StaticResource Botoes}"
                                    Command="{Binding AdicionarTipo}"/>
                        </Grid>
                        <!--
                        <ComboBox ItemsSource="{Binding Source={x:Static services:DadosService.Instance}, Path=ListaDeposito}">
                            
                        </ComboBox>
-->
                        <ItemsControl/>


                    </StackPanel>
                </Border>


                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Tipos de Itens:" Grid.Row="1" FontSize="16" FontWeight="Bold"
                               Margin="17,0,0,0"/>
                    <TextBox Grid.Column="1" HorizontalAlignment="Stretch" Margin="10,0,20,0"
                             Text="{Binding NomeTipoPesquisado, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>



                <ListBox Margin="10" Grid.Row="2" ItemsSource="{Binding ListaTipo}"
                         BorderBrush="Transparent" HorizontalContentAlignment="Stretch"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="10" HorizontalAlignment="Stretch" CornerRadius="10" BorderBrush="Gray" BorderThickness="1">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding NomeTipo}"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="auto"/>

                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Quantidade: "/>
                                        <TextBlock Grid.Column="1" Text="{Binding QuantidadeTipoEstoque}"/>

                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>

        </Grid>
        
    </Grid>
</UserControl>
