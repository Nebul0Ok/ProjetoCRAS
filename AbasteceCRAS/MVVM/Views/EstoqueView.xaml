<UserControl x:Class="AbasteceCRAS.MVVM.Views.EstoqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
             xmlns:services="clr-namespace:AbasteceCRAS.Services"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">

    <UserControl.Resources>
        
        
        
        <!-- Estilo para os labels (Item, Tipo, etc) -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Estilo para os botões de Alternância (Entrada/Saída) -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
             BorderBrush="{TemplateBinding BorderBrush}" 
             BorderThickness="1" 
             CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#888888" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="9.9*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="10*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" 
        Grid.Column="0" 
        Margin="10"
        Style="{StaticResource BotaoIcone}" 
        Width="50" 
        Height="50" 
        Command="{Binding VoltarHome}">

            <Image Source="{StaticResource IconeVoltarSeta}" 
           Stretch="Uniform" 
           Margin="5"/>

        </Button>


        <Grid Grid.Column="1" Grid.Row="1"  Background="White">
            <!-- Este container centraliza todo o conteúdo na tela -->
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="1200">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="650"/>
                </Grid.ColumnDefinitions>

                <!-- COLUNA DA ESQUERDA: FORMULÁRIO -->
                <StackPanel Grid.Column="0" Margin="20">
                    <TextBlock Text="Gerenciamento de Estoque" FontSize="26" FontWeight="Bold" Margin="0,0,0,25"/>

                    <Border BorderBrush="#EEE" BorderThickness="1.5" Padding="25" CornerRadius="15">
                        <StackPanel>
                            <TextBlock Text="Nova Movimentação" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="Qual ação irá fazer?" Style="{StaticResource FieldLabelStyle}"/>
                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <Button Content="+ Entrada" Command="{Binding SelecionarEntrada}"
                                        Background="Black" 
                                        Foreground="White" 
                                        Style="{StaticResource ToggleButtonStyle}"
                                        Margin="0,0,5,0"/>

                                <Button Content="- Saída" Command="{Binding SelecionarSaida}"
                                        Background="White"
                                        Foreground="Black"
                                        Style="{StaticResource ToggleButtonStyle}"
                                        Margin="5,0,0,0"/>
                            </UniformGrid>

                            <TextBlock Text="Item:" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Margin="0,0,0,15" ItemsSource="{Binding ListaItens}" SelectedItem="{Binding ItemSelecionado}"/>

                            <TextBlock Text="Tipo:" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Margin="0,0,0,15" ItemsSource="{Binding ListaTipos}" SelectedItem="{Binding TipoSelecionado}"/>

                            <TextBlock Text="Depósito:" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Margin="0,0,0,15" ItemsSource="{Binding ListaDepositos}"/>

                            <TextBlock Text="Quantidade:" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="0" Height="45" Background="#F0F4F8" BorderThickness="0" Margin="0,0,0,25" 
                      VerticalContentAlignment="Center" Padding="15,0" FontWeight="SemiBold"/>

                            <Button Content="+ Registrar Entrada" Background="Black" Foreground="White" Height="48" FontWeight="Bold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="20">
                    <Border BorderBrush="#EEE" BorderThickness="1.5" CornerRadius="15" Padding="25" MinHeight="500">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="7*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Estoque Atual" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ComboBox Width="150" HorizontalAlignment="Right" Height="30" SelectedIndex="0">
                                    <ComboBoxItem Content="Estoque Atual"/>
                                </ComboBox>
                            </Grid>



                            <ListBox Grid.Row="1"  ItemsSource="{Binding Source={x:Static services:DadosService.Instance}, Path=ListaProduto}"
                                      HorizontalContentAlignment="Stretch" 
                                      BorderThickness="0" 
                                      Background="Transparent"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="10,8" 
                        Background="White" 
                        CornerRadius="15" 
                        Padding="20"
                        BorderBrush="#F0F0F0"
                        BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0" 
Command="{Binding DataContext.DiminuirLista, RelativeSource={RelativeSource AncestorType=ListBox}}"
CommandParameter="{Binding}"
Width="32" Height="32" 
Cursor="Hand">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#E9ECEF"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>

                                                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="#495057">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="▶"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Expandido}" Value="True">
                                                                            <Setter Property="Text" Value="▼"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>

                                                    <TextBlock Grid.Column="1" 
                                       Text="{Binding NomeItem}" 
                                       FontSize="17" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0"
                                       Foreground="#212529"/>

                                                    <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="8" Padding="10,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="📦 " FontSize="10" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ESTOQUE" FontSize="10" FontWeight="Black" Foreground="#1976D2"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <ItemsControl Grid.Row="1" 
                                       ItemsSource="{Binding TipoDeItems}" 
                                       Margin="47,15,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Expandido}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#F8F9FA" BorderThickness="0,0,0,1" Padding="0,10">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="3*"/>
                                                                        <ColumnDefinition Width="3*"/>
                                                                        <ColumnDefinition Width="2*"/>
                                                                        <ColumnDefinition Width="auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Text="{Binding NomeTipo}" 
                                                       Foreground="#6C757D" 
                                                       FontSize="14" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                                                    <TextBlock Grid.Column="1" Text="{Binding DepositoAtual.Nome}" Margin="10,0,0,0" FontSize="12"
                                                        VerticalAlignment="Top" HorizontalAlignment="Center"/>

                                                                    <TextBlock Grid.Column="2" Text="{Binding DepositoAtual.Localizacao}" Margin="10,0,10,0" FontSize="12"
                                                        VerticalAlignment="Top" HorizontalAlignment="Center"/>

                                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">

                                                                        <TextBlock Text="{Binding QuantidadeTipoEstoque}" 
                                                            FontWeight="Bold" 
                                                            Foreground="#28a745" 
                                                            FontSize="14"/>

                                                                        <TextBlock Text=" un" FontSize="12" Foreground="#ADB5BD" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Lista de Itens (ItemsControl) -->
                            <ItemsControl ItemsSource="{Binding ListaItensEstoque}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Margin="0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding NomeItem}" VerticalAlignment="Center" Grid.Column="0" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Tipo}" VerticalAlignment="Center" Grid.Column="1" Foreground="#666"/>
                                                <TextBlock Text="{Binding NomeDeposito}" VerticalAlignment="Center" Grid.Column="2" Foreground="#666"/>

                                                <Border Grid.Column="3" Background="#E8F5E9" Padding="10,5" CornerRadius="8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📦" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="12"/>
                                                        <TextBlock Text="{Binding Quantidade}" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <Separator Background="#F5F5F5"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>


    </Grid>

    

</UserControl>
