 <UserControl x:Class="AbasteceCRAS.MVVM.Views.DepositoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">


    <UserControl.Resources>
        <!-- Estilo para os labels (Item, Tipo, etc) -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Estilo para os botões de Alternância (Entrada/Saída) -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <!-- Este container centraliza todo o conteúdo na tela -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="1200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="650"/>
            </Grid.ColumnDefinitions>

            <!-- COLUNA DA ESQUERDA: FORMULÁRIO -->
            <StackPanel Grid.Column="0" Margin="20">
                <TextBlock Text="Gerenciamento de Estoque" FontSize="26" FontWeight="Bold" Margin="0,0,0,25"/>

                <Border BorderBrush="#EEE" BorderThickness="1.5" Padding="25" CornerRadius="15">
                    <StackPanel>
                        <TextBlock Text="Nova Movimentação" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Qual ação irá fazer?" Style="{StaticResource FieldLabelStyle}"/>
                        <UniformGrid Columns="2" Margin="0,0,0,20">
                            <Button Content="+ Entrada" Background="Black" Foreground="White" Style="{StaticResource ToggleButtonStyle}" Margin="0,0,5,0"/>
                            <Button Content="- Saída" Background="White" Foreground="Black" Style="{StaticResource ToggleButtonStyle}" Margin="5,0,0,0"/>
                        </UniformGrid>

                        <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource RoundedComboBoxStyle}" Margin="0,0,0,15" ItemsSource="{Binding ItensDisponiveis}"/>

                        <TextBlock Text="Tipo" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource RoundedComboBoxStyle}" Margin="0,0,0,15" ItemsSource="{Binding TiposDisponiveis}"/>

                        <TextBlock Text="Depósito" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource RoundedComboBoxStyle}" Margin="0,0,0,15" ItemsSource="{Binding ListaDepositos}"/>

                        <TextBlock Text="Quantidade" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="0" Height="45" Background="#F0F4F8" BorderThickness="0" Margin="0,0,0,25" 
                             VerticalContentAlignment="Center" Padding="15,0" FontWeight="SemiBold"/>

                        <Button Content="+ Registrar Entrada" Background="Black" Foreground="White" Height="48" FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- COLUNA DA DIREITA: ESTOQUE ATUAL -->
            <StackPanel Grid.Column="1" Margin="20">
                <Border BorderBrush="#EEE" BorderThickness="1.5" CornerRadius="15" Padding="25" MinHeight="500">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Estoque Atual" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <ComboBox Width="150" HorizontalAlignment="Right" Height="30" SelectedIndex="0">
                                <ComboBoxItem Content="Estoque Atual"/>
                            </ComboBox>
                        </Grid>

                        <!-- Cabeçalho da Tabela -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" FontWeight="Bold" Grid.Column="0" Foreground="#666"/>
                            <TextBlock Text="Tipo" FontWeight="Bold" Grid.Column="1" Foreground="#666"/>
                            <TextBlock Text="Depósito" FontWeight="Bold" Grid.Column="2" Foreground="#666"/>
                            <TextBlock Text="Quantidade" FontWeight="Bold" Grid.Column="3" Foreground="#666" Margin="0,0,10,0"/>
                        </Grid>

                        <Separator Background="#EEE" Margin="0,0,0,10"/>

                        <!-- Lista de Itens (ItemsControl) -->
                        <ItemsControl ItemsSource="{Binding ListaItensEstoque}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Margin="0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding NomeItem}" VerticalAlignment="Center" Grid.Column="0" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Tipo}" VerticalAlignment="Center" Grid.Column="1" Foreground="#666"/>
                                            <TextBlock Text="{Binding NomeDeposito}" VerticalAlignment="Center" Grid.Column="2" Foreground="#666"/>

                                            <Border Grid.Column="3" Background="#E8F5E9" Padding="10,5" CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📦" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="12"/>
                                                    <TextBlock Text="{Binding Quantidade}" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Separator Background="#F5F5F5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
