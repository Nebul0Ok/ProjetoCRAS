<UserControl x:Class="AbasteceCRAS.MVVM.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Background="White">

        <!-- Layout principal -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="1300">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="40,20">

                <!-- Título -->
                <TextBlock Text="Bem-vindo ao Sistema de Gestão CRAS"
                           FontSize="32"
                           FontWeight="Bold"/>

                <TextBlock Text="Selecione uma opção para continuar"
                           FontSize="18"
                           Margin="0,5,0,20"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- Estoque -->
                    <Button Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource CardButtonStyle}"
                            Tag="#64B568"
                            Uid="#407D43"
                            Width="260"
                            Height="140"
                            Margin="8"
                            Background="White"
                            BorderBrush="#2e7d32"
                            Command="{Binding NavegarEstoque}">
                        <StackPanel VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                Height="60"
                                HorizontalAlignment="Center">

                                <Canvas Name="svg2" Width="16" Height="16">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform X="0" Y="0"/>
                                    </Canvas.RenderTransform>
                                    <Canvas.Resources/>
                                    <!--Unknown tag: sodipodi:namedview-->
                                    <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="path1" Fill="#2e7d32">
                                        <Path.Data>
                                            <PathGeometry Figures="M12 6v-6h-8v6h-4v7h16v-7h-4zM7 12h-6v-5h2v1h2v-1h2v5zM5 6v-5h2v1h2v-1h2v5h-6zM15 12h-6v-5h2v1h2v-1h2v5z" FillRule="NonZero"/>
                                        </Path.Data>
                                    </Path>
                                </Canvas>

                            </Viewbox>

                            <TextBlock Text="Estoque"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="#2e7d32"
                                       />
                        </StackPanel>
                    </Button>

                    <!-- Depósitos -->
                    <Button Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource CardButtonStyle}"
                            Width="260"
                            Height="140"
                            Margin="8"
                            Tag="#5699E3"
                            Uid="#346499"
                            Background="White"
                            BorderBrush="#1565c0"
                            Command="{Binding NavegarDeposito}">
                        <StackPanel VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                Height="60"
                                HorizontalAlignment="Center">

                                <Canvas Name="svg4" Width="24" Height="24">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform X="0" Y="0"/>
                                    </Canvas.RenderTransform>
                                    <Canvas.Resources/>
                                    <!--Unknown tag: sodipodi:namedview-->
                                    <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="path3" Fill="#1565c0">
                                        <Path.Data>
                                            <PathGeometry Figures="M13.4948 4.33224C12.6423 3.57447 11.3577 3.57447 10.5052 4.33224L4.50518 9.66558C4.02483 10.0926 3.75 10.7046 3.75 11.3472V21.2501H5.25L5.25 15.948C5.24997 15.0496 5.24994 14.3004 5.32991 13.7056C5.41432 13.0778 5.59999 12.511 6.05546 12.0555C6.51093 11.6 7.07773 11.4144 7.70552 11.33C8.3003 11.25 9.04952 11.25 9.94801 11.25H14.052C14.9505 11.25 15.6997 11.25 16.2945 11.33C16.9223 11.4144 17.4891 11.6 17.9445 12.0555C18.4 12.511 18.5857 13.0778 18.6701 13.7056C18.7501 14.3004 18.75 15.0496 18.75 15.9481V21.2501H20.25V11.3472C20.25 10.7046 19.9752 10.0926 19.4948 9.66558L13.4948 4.33224ZM21.75 21.2501V11.3472C21.75 10.2761 21.2919 9.25609 20.4914 8.54446L14.4914 3.21113C13.0705 1.94818 10.9295 1.94818 9.50864 3.21113L3.50864 8.54446C2.70805 9.25609 2.25 10.2761 2.25 11.3472V21.2501H2C1.58579 21.2501 1.25 21.5858 1.25 22.0001C1.25 22.4143 1.58579 22.7501 2 22.7501H22C22.4142 22.7501 22.75 22.4143 22.75 22.0001C22.75 21.5858 22.4142 21.2501 22 21.2501H21.75ZM17.25 21.2501V16.0001C17.25 15.036 17.2484 14.3885 17.1835 13.9054C17.1214 13.444 17.0142 13.2465 16.8839 13.1162C16.7536 12.9859 16.5561 12.8786 16.0946 12.8166C15.6116 12.7516 14.964 12.7501 14 12.7501H10C9.03599 12.7501 8.38843 12.7516 7.90539 12.8166C7.44393 12.8786 7.24643 12.9859 7.11612 13.1162C6.9858 13.2465 6.87858 13.444 6.81654 13.9054C6.75159 14.3885 6.75 15.036 6.75 16.0001V21.2501H17.25ZM9.25 9.00005C9.25 8.58584 9.58579 8.25005 10 8.25005H14C14.4142 8.25005 14.75 8.58584 14.75 9.00005C14.75 9.41426 14.4142 9.75005 14 9.75005H10C9.58579 9.75005 9.25 9.41426 9.25 9.00005ZM8.25 15.5001C8.25 15.0858 8.58579 14.7501 9 14.7501H15C15.4142 14.7501 15.75 15.0858 15.75 15.5001C15.75 15.9143 15.4142 16.2501 15 16.2501H9C8.58579 16.2501 8.25 15.9143 8.25 15.5001ZM8.25 18.5001C8.25 18.0858 8.58579 17.7501 9 17.7501H15C15.4142 17.7501 15.75 18.0858 15.75 18.5001C15.75 18.9143 15.4142 19.25 15 19.25H9C8.58579 19.25 8.25 18.9143 8.25 18.5001Z" FillRule="EvenOdd"/>
                                        </Path.Data>
                                    </Path>
                                </Canvas>

                            </Viewbox>

                            <TextBlock Text="Depósitos"
                                       FontSize="20"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Itens -->
                    <Button Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource CardButtonStyle}"
                            Width="260"
                            Height="140"
                            Margin="8"
                            Tag="#F0844D"
                            Uid="#C46335"
                            Background="White"
                            BorderBrush="#e65100"
                            Command="{Binding NavegarItens}">
                        <StackPanel VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                Height="60"
                                HorizontalAlignment="Center">

                                <Canvas Name="svg6" Width="24" Height="24">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform X="0" Y="0"/>
                                    </Canvas.RenderTransform>
                                    <Canvas.Resources/>
                                    <!--Unknown tag: sodipodi:namedview-->
                                    <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="path2" StrokeThickness="1.5" Stroke="#e65100" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Data>
                                            <PathGeometry Figures="M21.9844 10C21.9473 8.68893 21.8226 7.85305 21.4026 7.13974C20.8052 6.12523 19.7294 5.56066 17.5777 4.43152L15.5777 3.38197C13.8221 2.46066 12.9443 2 12 2C11.0557 2 10.1779 2.46066 8.42229 3.38197L6.42229 4.43152C4.27063 5.56066 3.19479 6.12523 2.5974 7.13974C2 8.15425 2 9.41667 2 11.9415V12.0585C2 14.5833 2 15.8458 2.5974 16.8603C3.19479 17.8748 4.27063 18.4393 6.42229 19.5685L8.42229 20.618C10.1779 21.5393 11.0557 22 12 22C12.9443 22 13.8221 21.5393 15.5777 20.618L17.5777 19.5685C19.7294 18.4393 20.8052 17.8748 21.4026 16.8603C21.8226 16.1469 21.9473 15.3111 21.9844 14" FillRule="NonZero"/>
                                        </Path.Data>
                                    </Path>
                                    <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="path4" StrokeThickness="1.5" Stroke="#e65100" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Data>
                                            <PathGeometry Figures="M21 7.5L17 9.5M12 12L3 7.5M12 12V21.5M12 12C12 12 14.7426 10.6287 16.5 9.75C16.6953 9.65237 17 9.5 17 9.5M17 9.5V13M17 9.5L7.5 4.5" FillRule="NonZero"/>
                                        </Path.Data>
                                    </Path>
                                </Canvas>

                            </Viewbox>

                            <TextBlock Text="Itens"
                                       FontSize="20"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Histórico -->
                    <Button Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource CardButtonStyle}"
                            Width="260"
                            Height="140"
                            Margin="8"
                            Tag="#C26BAB"
                            Uid="#823B6F"
                            Background="White"
                            BorderBrush="#8f3176"
                            Command="{Binding NavegarHistorico}">
                        <StackPanel VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform"
                                Height="60"
                                HorizontalAlignment="Center">

                                <Canvas Name="historic16px" Width="16" Height="16">
                                    <Canvas.RenderTransform>
                                        <TranslateTransform X="0" Y="1"/>
                                    </Canvas.RenderTransform>
                                    <Canvas.Resources/>
                                    <!--Unknown tag: sodipodi:namedview-->
                                    <Path xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Name="Path_89" Fill="#8f3176">
                                        <Path.Data>
                                            <PathGeometry Figures="M-5 8a7.008 7.008 0 0 1-7 7 .5.5 0 0 1-.5-.5A.5.5 0 0 1-12 14 6.006 6.006 0 0 0-6 8a6.006 6.006 0 0 0-6-6 6.006 6.006 0 0 0-6 6v.293l1.146-1.147a.5.5 0 0 1 .708 0 .5.5 0 0 1 0 .708l-2 2a.518.518 0 0 1-.163.109A.5.5 0 0 1-18.5 10a.5.5 0 0 1-.191-.038.518.518 0 0 1-.163-.109l-2-2a.5.5 0 0 1 0-.708.5.5 0 0 1 .708 0L-19 8.293V8a7.008 7.008 0 0 1 7-7A7.008 7.008 0 0 1-5 8Zm-7-4a.5.5 0 0 0-.5.5V8a.5.5 0 0 0 .5.5h3.5A.5.5 0 0 0-8 8a.5.5 0 0 0-.5-.5h-3v-3A.5.5 0 0 0-12 4Z" FillRule="NonZero"/>
                                        </Path.Data>
                                        <Path.RenderTransform>
                                            <TranslateTransform X="21" Y="-1"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Canvas>
                            </Viewbox>

                            <TextBlock Text="Histórico"
                                       FontSize="20"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </StackPanel>

            <Grid Grid.Column="1"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left"
                  Margin="40">

                <Image Source="/Assets/cras-seeklogo.png"
                       Stretch="Uniform"
                       MinHeight="200"
                       MinWidth="200"
                       MaxHeight="400"
                       MaxWidth="400"/>
            </Grid>

        </Grid>
    </Grid>
</UserControl>