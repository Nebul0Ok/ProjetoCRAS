<Window x:Class="AbasteceCRAS.MVVM.Views.TelaLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbasteceCRAS.MVVM.Views"
        mc:Ignorable="d"
        Title="AbasteceCRAS - Login" Height="450" Width="800">
    <Grid Background="Gray">

        <Border Background="White" CornerRadius="20" Width="220" Height="300">
            <StackPanel Margin="10">
                <TextBlock Text="Login" FontSize="25" Foreground="Navy"/>
                <Separator Margin="10" />
                <TextBlock Text="E-mail:"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                <Separator Margin="10" Background="Transparent" />
                <TextBlock Text="Senha:"/>
                <PasswordBox PasswordChanged="PasswordBox_PasswordChanged"/>
                <Separator Margin="10" Background="Transparent" />
                <Button Content="Esqueceu a senha?" 
                        Foreground="Blue" Background="Transparent" BorderBrush="Transparent" 
                        Width="auto" Height="auto" HorizontalAlignment="Left"/>

                <Separator Margin="10" Background="Transparent" />

                <Button Content="Confirmar" Width="70" Height="30"
                        Command="{Binding RealizarLogin}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Border>
        
        
    </Grid>
</Window>
