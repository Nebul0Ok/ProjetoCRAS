<Application x:Class="AbasteceCRAS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AbasteceCRAS"
             xmlns:vm="clr-namespace:AbasteceCRAS.MVVM.ViewModels"
             xmlns:views="clr-namespace:AbasteceCRAS.MVVM.Views"
             StartupUri="MVVM/Views/TelaLogin.xaml">
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/BotoesCards.xaml"/>
                <ResourceDictionary Source="/Styles/Icones.xaml"/>
                <ResourceDictionary Source="/Styles/BotaoIcone.xaml"/>
                <ResourceDictionary Source="/Styles/EstiloBotao.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!--
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:TelaLogin/>
            </DataTemplate>
            -->
            
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomeView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DepositoViewModel}">
                <views:DepositoView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ItensViewModel}">
                <views:ItensView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
                <views:EstoqueView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:HistoricoViewModel}">
                <views:HistoricoView/>
            </DataTemplate>


        </ResourceDictionary>



    </Application.Resources>
</Application>
